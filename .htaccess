DirectoryIndex index.html

RewriteEngine On

# Rediriger /index.html vers la racine du site
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Forcer le domaine officiel avec www si le domaine est configure sur le serveur
RewriteCond %{HTTP_HOST} ^biotechagro\.com$ [NC]
RewriteRule ^(.*)$ https://www.BiotechAgro.com/$1 [R=301,L]
